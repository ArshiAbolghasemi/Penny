{
  "data_dir": "data/stocks/lobster",
  "checkpoint_dir": "checkpoints/stocks/lobster/penny",
  "feature_mode": "ofi",
  "device": "cpu",
  "seed": 42,
  "T_past": 50,
  "T_max": 100,
  "beta_start": 0.0001,
  "beta_end": 0.02,
  "batch_size": 32,
  "epochs": 3,
  "patience": 2,
  "lr": 0.0005,
  "weight_decay": 0.01,
  "lambda_trend": 1.0,
  "trend_taper": true,
  "grad_clip": 1.0,
  "n_lob_levels": 10,
  "train_frac": 0.7,
  "val_frac": 0.15,
  "cond_drop_prob": 0.1,
  "model": {
    "rnn_type": "gru",
    "hidden_dim": 64,
    "num_layers": 2,
    "diffusion_steps": 100
  }
}
